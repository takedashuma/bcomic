# ============================================================
# zcomic-next 環境変数テンプレート
# 全ての環境依存値はこのファイルで管理する。コード内ハードコード禁止。
# .env にコピーして編集してください: cp .env.example .env
# ============================================================

# ===== Database =====
# 既存 MariaDB の接続情報
DB_HOST=192.168.40.99
DB_PORT=3306
DB_NAME=comic
DB_USER=root
DB_PASSWORD=change-me

# Prisma用の接続文字列（DB_*から組み立ててもよいが、Prismaが直接読むのはこちら）
DATABASE_URL=mysql://root:change-me@192.168.40.99:3306/comic

# ===== Comic file root =====
# ホスト側のコミック画像ディレクトリ（read-only でコンテナにマウント）
# Mac の /Volumes (SMBマウント) を bind するとアクセス権限エラーが出る場合は、
# 下の SMB 直接マウント（対処B）に切り替えるか、Docker Desktop Settings → Resources → File sharing に /Volumes を追加。
COMIC_ROOT_HOST=/Volumes/public/Comic/Renamed
COMIC_ROOT_CONTAINER=/comics

# ===== 対処B: NAS SMB を Docker から直接マウントする場合に使う =====
# 使用時は docker-compose.yml の comic_data volume を有効化
SMB_HOST=192.168.40.99
SMB_SHARE=public
SMB_USER=
SMB_PASSWORD=

# ===== Auth =====
# 16文字以上のランダム文字列にすること
JWT_SECRET=please-change-me-to-a-random-secret
JWT_EXPIRES_IN=7d
# Cookieドメイン（特定ドメインに限定したい場合のみ）
COOKIE_DOMAIN=
# HTTPS本番では true、HTTP開発では false
COOKIE_SECURE=false

# ===== Web =====
# 本番ビルド時にフロントが叩くAPIベースURL。
# 空文字（推奨）= 相対URL = ブラウザの現在オリジンへ送る（LAN/外部DDNS両対応）。
VITE_API_URL=""

# vite dev サーバ（ローカル開発時）が /graphql, /img をプロキシする先
VITE_DEV_API_PROXY=http://localhost:4000
VITE_DEV_PORT=5173

# ===== CORS =====
# APIが許可するOrigin（カンマ区切り）。Web画面を開く可能性のあるURLを全て列挙
CORS_ORIGINS=http://192.168.40.99:8080,http://192.168.40.99:4000,http://dirs.synology.me:8080,http://dirs.synology.me:4000,https://dirs.synology.me,http://localhost:8080,http://localhost:4000,http://localhost:5173

# ===== Ports =====
WEB_PORT=8080
API_PORT=4000


# ============================================================
# 管理サイト (api-admin / web-admin)
# 本サイトと完全に分離されたコンテナ・コードベース
# ============================================================

# Admin Prisma 用接続文字列（DATABASE_URL と共有 or 専用ユーザー）
ADMIN_DATABASE_URL=mysql://root:change-me@192.168.40.99:3306/comic

# Admin JWT（本サイトと必ず別の値・別 Cookie 名(zc_admin_token)で運用）
ADMIN_JWT_SECRET=please-change-me-admin-secret
ADMIN_JWT_EXPIRES_IN=1d

# Admin 用 CORS
ADMIN_CORS_ORIGINS=http://192.168.40.99:8081,http://192.168.40.99:4001,http://localhost:8081,http://localhost:4001,http://localhost:5174

# Admin ビルド時APIベースURL（空文字=相対URL推奨）
VITE_ADMIN_API_URL=""

# Admin dev サーバプロキシ
VITE_ADMIN_DEV_API_PROXY=http://localhost:4001
VITE_ADMIN_DEV_PORT=5174

# 作業領域（フォルダ移動・削除・作成 等の共通ルート。通常は COMIC_ROOT と同一）
STAGING_ROOT_HOST=/Volumes/public/Comic/Renamed
STAGING_ROOT_CONTAINER=/staging

# /Volumes/public/Download をまとめて1ボリュームでマウント。
# サブフォルダ Zip / Unzip / zFin / Chapter を使う。
# 解凍後の移動先と元アーカイブ退避先を同じ親に置くことで cross-device rename を回避。
DOWNLOAD_ROOT_HOST=/Volumes/public/Download
DOWNLOAD_ROOT_CONTAINER=/download_root

EXTRACT_ARCHIVE_DIR=/download_root/Zip
EXTRACT_ER_ARCHIVE_DIR=/download_root/Zip
UNZIP_DEST_DIR=/download_root/Unzip
ARCHIVE_DONE_DIR=/download_root/zFin
# UNZIP_DEST_DIR_ER=/download_root/Unzip_ER
# ARCHIVE_DONE_DIR_ER=/download_root/zFin_ER

MERGE_CHAPTER_DIR=/download_root/Chapter

# Page取得 (13dl) の登録フォルダ作成ルート
REGIST_DIR=/download_root/Regist

# Admin ポート
ADMIN_API_PORT=4001
ADMIN_WEB_PORT=8081
